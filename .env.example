# Copied at build time into the app. For Vercel: Settings → Environment Variables → add REACT_APP_API_URL → redeploy.
# Use your deployed API origin only (no /api/v1 required; the client adds it).
# Production example:
# REACT_APP_API_URL=https://your-backend-project.vercel.app

REACT_APP_API_URL=http://localhost:4000/api/v1
